{
  "name": "doubao-studio-desktop",
  "version": "1.5.0",
  "description": "豆包工作室 - AI 内容创作者多账号管理与自动化生产工作台",
  "main": "dist/main/main.js",
  "author": "Doubao Studio Team",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "node node_modules/vite/bin/vite.js",
    "dev:main": "wait-on http://localhost:5173 && pnpm run build:main && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "node node_modules/vite/bin/vite.js build",
    "build": "pnpm run build:renderer && pnpm run build:main",
    "start": "electron .",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win",
    "lint": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "ts-check": "tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json",
    "lint:build": "eslint . --quiet",
    "validate": "pnpm run --parallel '/^(ts-check|lint:build)$/'"
  },
  "dependencies": {
    "antd": "^5.22.0",
    "@ant-design/icons": "^5.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.doubao.studio.desktop",
    "productName": "豆包工作室",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "data",
        "to": "data"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "豆包工作室"
    }
  }
}

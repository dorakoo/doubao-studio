{
  "name": "doubao-studio-desktop",
  "version": "2.1.0",
  "description": "豆包工作室 - AI 内容创作者多账号管理与自动化生产工作台",
  "main": "dist/main/main.js",
  "author": "Doubao Studio Team",
  "license": "MIT",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:renderer": "node node_modules/vite/bin/vite.js",
    "dev:main": "wait-on http://localhost:5173 && pnpm run build:main && electron .",
    "build:contracts": "tsc -p packages/contracts/tsconfig.json",
    "build:main": "pnpm run build:contracts && tsc -p tsconfig.main.json",
    "build:renderer": "node node_modules/vite/bin/vite.js build",
    "build": "pnpm run build:renderer && pnpm run build:main",
    "start": "electron .",
    "pack": "pnpm run build && electron-builder --dir",
    "dist": "pnpm run build && electron-builder",
    "dist:win": "pnpm run build && electron-builder --win",
    "lint": "eslint . --max-warnings 149",
    "ts-check": "pnpm run build:contracts && tsc --noEmit -p tsconfig.main.json && tsc --noEmit -p tsconfig.renderer.json && tsc --noEmit -p tsconfig.test.json",
    "check:project": "node scripts/fixtures/run-fixture-tests.mjs && node scripts/fixtures/run-contracts-fixtures.mjs && node scripts/check-project.mjs && node scripts/check-contracts-boundary.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "validate": "pnpm run ts-check && pnpm run lint && pnpm run check:project && pnpm run test && pnpm run build"
  },
  "dependencies": {
    "@ant-design/icons": "^5.5.0",
    "antd": "^5.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "uuid": "^10.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@doubao-studio/contracts": "workspace:*",
    "@eslint/js": "^9.39.4",
    "@types/node": "26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^3.2.7",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0",
    "vite": "^6.0.3",
    "vitest": "^3.2.7",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.doubao.studio.desktop",
    "productName": "豆包工作室",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "豆包工作室"
    }
  }
}

[project]
requires = ["nodejs-24"]

[dev]
build = ["pnpm", "install"]
# 开发模式：编译主进程 TypeScript + 启动 Vite 开发服务器
# Electron GUI 需要桌面环境，沙箱中仅做编译验证
run = ["pnpm", "run", "build:main"]

[deploy]
build = ["pnpm", "run", "build"]
# 生产构建后输出 release/ 目录，在本地机器上执行 electron .
run = ["sh", "-c", "echo 'Electron 桌面应用已构建完成，请在本地机器上运行: pnpm start'"]

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "noEmit": true,
    "declaration": false,
    "declarationMap": false
  },
  "include": [
    "tests/**/*.ts",
    "tests/**/*.tsx",
    "vitest.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "release"
  ]
}
